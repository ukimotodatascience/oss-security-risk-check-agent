TARGET_DIR=xxxxx
# レポート（.md）の保存先。未設定時はプロジェクト直下の .reports
OUTPUT_DIR=xxxxx

# ---- Vulnerability provider settings (B-1) ----
# 利用順序（カンマ区切り）: osv, github, nvd
VULN_PROVIDER_ORDER=osv,github,nvd

# APIキー（必要に応じて設定）
OSV_API_KEY=
GITHUB_TOKEN=
NVD_API_KEY=

# タイムアウト/リトライ
VULN_API_TIMEOUT_SEC=10
VULN_MAX_RETRIES=2

# true: 複数プロバイダを順に参照 / false: 最初にヒットしたプロバイダのみ
VULN_ENABLE_FALLBACK=true
